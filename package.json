{
  "name": "@insaneduck/rich-text-editor",
  "version": "0.0.1",
  "description": "A Lexical-based rich text editor component for React",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InsaneDuck/rich-text-editor.git"
  },
  "bugs": {
    "url": "https://github.com/InsaneDuck/rich-text-editor/issues"
  },
  "homepage": "https://github.com/InsaneDuck/rich-text-editor#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
